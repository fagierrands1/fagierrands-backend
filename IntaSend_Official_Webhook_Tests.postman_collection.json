  "item": [
    {
      "name": "1. Official Format - Payment Complete ✅",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success status\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"success\");",
              "});",
              "",
              "pm.test(\"Response time is less than 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "User-Agent",
            "value": "IntaSend-Webhook"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"invoice_id\": \"BRZKGPR{{$randomInt}}\",\n  \"state\": \"COMPLETE\",\n  \"provider\": \"M-PESA\",\n  \"charges\": \"3.00\",\n  \"net_amount\": \"97.00\",\n  \"currency\": \"KES\",\n  \"value\": \"100.00\",\n  \"account\": \"QGH{{$randomAlphaNumeric}}{{$randomAlphaNumeric}}\",\n  \"api_ref\": \"ISL_{{$guid}}\",\n  \"host\": \"https://payment.intasend.com\",\n  \"failed_reason\": null,\n  \"failed_code\": null,\n  \"failed_code_link\": \"https://intasend.com/troubleshooting\",\n  \"created_at\": \"{{$isoTimestamp}}\",\n  \"updated_at\": \"{{$isoTimestamp}}\",\n  \"challenge\": \"production\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{webhook_url}}",
          "host": ["{{webhook_url}}"]
        },
        "description": "Test official IntaSend webhook format for completed payment"
      },
      "response": []
    },
