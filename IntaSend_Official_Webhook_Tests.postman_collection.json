{
  "info": {
    "_postman_id": "official-webhook-test-collection",
    "name": "IntaSend Official Webhook Tests",
    "description": "Official IntaSend webhook format tests based on documentation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
