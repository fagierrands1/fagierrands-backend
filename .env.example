# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Supabase Configuration (Fallback Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# MediaFire Storage Configuration (Primary Storage)
# Get these credentials from https://www.mediafire.com/developers/
MEDIAFIRE_APP_ID=your_mediafire_app_id
MEDIAFIRE_API_KEY=your_mediafire_api_key
MEDIAFIRE_EMAIL=your_mediafire_email@example.com
MEDIAFIRE_PASSWORD=your_mediafire_password
MEDIAFIRE_FOLDER_KEY=  # Optional: leave empty to auto-create folders

# Email Configuration (Brevo SMTP)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-brevo-email@example.com
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# M-Pesa Configuration
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=your-shortcode
MPESA_PASSKEY=your-passkey

# NCBA Payment Settings
NCBA_USERNAME=your-ncba-username
NCBA_PASSWORD=your-ncba-password
NCBA_PAYBILL_NO=your-ncba-paybill-no
NCBA_TILL_NO=your-ncba-till-no
NCBA_TRANSACTION_TYPE=CustomerPayBillOnline
NCBA_USE_TILL_AS_ACCOUNT=False

# M-Pesa B2C Configuration
MPESA_B2C_SHORTCODE=your-b2c-shortcode
MPESA_B2C_INITIATOR_NAME=your-initiator-name
MPESA_B2C_SECURITY_CREDENTIAL=your-security-credential

# Base URL for callbacks
BASE_URL=http://localhost:8000

# Redis Configuration (Optional - for Celery)
REDIS_URL=redis://localhost:6379/0

# Web Push Notifications
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
WEBPUSH_EMAIL=admin@yourdomain.com

# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key