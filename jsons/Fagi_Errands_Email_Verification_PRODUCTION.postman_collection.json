{
	"info": {
		"_postman_id": "87654321-4321-4321-4321-210987654321",
		"name": "Fagi Errands - Email Verification (PRODUCTION)",
		"description": "Production test collection for email verification system on fagierrands-server.vercel.app",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Register User (Production)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"User registered successfully\", function () {",
							"    pm.response.to.have.status(201);",
							"    const response = pm.response.json();",
							"    pm.expect(response).to.have.property('username');",
							"    pm.expect(response).to.have.property('email');",
							"    console.log('✅ User registered:', response.username);",
							"    console.log('📧 Email verification sent to:', response.email);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{prod_username}}\",\n    \"email\": \"{{prod_email}}\",\n    \"password\": \"{{prod_password}}\",\n    \"password2\": \"{{prod_password}}\",\n    \"first_name\": \"Production\",\n    \"last_name\": \"Test\"\n}"
				},
				"url": {
					"raw": "{{prod_base_url}}/api/accounts/register/",
					"host": [
						"{{prod_base_url}}"
					],
					"path": [
						"api",
						"accounts",
						"register",
						""
					]
				}
			}
		},
		{
			"name": "2. Login User (Production)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Login successful\", function () {",
							"    pm.response.to.have.status(200);",
							"    const response = pm.response.json();",
							"    pm.expect(response).to.have.property('access');",
							"    pm.environment.set(\"prod_access_token\", response.access);",
							"    console.log('✅ Login successful');",
							"    console.log('🔑 Access token saved');",
							"    console.log('📧 Email verified:', response.user.email_verified);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{prod_username}}\",\n    \"password\": \"{{prod_password}}\"\n}"
				},
				"url": {
					"raw": "{{prod_base_url}}/api/accounts/login/",
					"host": [
						"{{prod_base_url}}"
					],
					"path": [
						"api",
						"accounts",
						"login",
						""
					]
				}
			}
		},
		{
			"name": "3. Check Email Verification Status (Production)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Email verification status retrieved\", function () {",
							"    pm.response.to.have.status(200);",
							"    const response = pm.response.json();",
							"    pm.expect(response).to.have.property('email_verified');",
							"    pm.expect(response).to.have.property('email');",
							"    console.log('📧 Email:', response.email);",
							"    console.log('✅ Verified:', response.email_verified);",
							"    ",
							"    if (!response.email_verified) {",
							"        console.log('⚠️ Email not verified yet. Check your inbox!');",
							"    } else {",
							"        console.log('🎉 Email is verified!');",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{prod_access_token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "{{prod_base_url}}/api/accounts/check-email-verification/",
					"host": [
						"{{prod_base_url}}"
					],
					"path": [
						"api",
						"accounts",
						"check-email-verification",
						""
					]
				}
			}
		},
		{
			"name": "4. Resend Verification Email (Production)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Resend verification response\", function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response).to.have.property('success');",
							"    pm.expect(response).to.have.property('message');",
							"    ",
							"    if (response.success) {",
							"        console.log('✅ Verification email resent successfully');",
							"        console.log('📧 Check your inbox for the new email');",
							"    } else {",
							"        console.log('⚠️ Resend failed:', response.message);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{prod_email}}\"\n}"
				},
				"url": {
					"raw": "{{prod_base_url}}/api/accounts/resend-verification/",
					"host": [
						"{{prod_base_url}}"
					],
					"path": [
						"api",
						"accounts",
						"resend-verification",
						""
					]
				}
			}
		},
		{
			"name": "5. Test API Health (Production)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"API is healthy\", function () {",
							"    pm.response.to.have.status(200);",
							"    console.log('✅ Production API is healthy');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
