{
  "info": {
    "_postman_id": "webhook-test-collection",
    "name": "IntaSend Webhook Tests",
    "description": "Complete test collection for IntaSend webhook endpoint validation",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Payment Completed ✅",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has success status\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"success\");",
              "});",
              "",
              "pm.test(\"Response time is less than 5000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "User-Agent",
            "value": "IntaSend-Webhook-Test"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"payment.completed\",\n  \"data\": {\n    \"invoice\": {\n      \"id\": \"{{test_invoice_id}}-completed\"\n    },\n    \"mpesa_receipt\": \"{{test_receipt}}\",\n    \"amount\": 100.00,\n    \"currency\": \"KES\",\n    \"phone_number\": \"254700000000\",\n    \"account\": \"Test Account\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{webhook_url}}",
          "host": ["{{webhook_url}}"]
        },
        "description": "Test successful payment completion webhook"
      },
      "response": []
    },
