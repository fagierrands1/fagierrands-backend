    {
      "name": "6. Endpoint Health Check 🏥",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Endpoint is accessible\", function () {",
              "    pm.response.to.not.have.status(404);",
              "});",
              "",
              "pm.test(\"Server is responding\", function () {",
              "    pm.response.to.not.have.status(500);",
              "});",
              "",
              "pm.test(\"Response time is reasonable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"health.check\",\n  \"data\": {\n    \"test\": true,\n    \"timestamp\": \"{{$isoTimestamp}}\"\n  }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{webhook_url}}",
          "host": ["{{webhook_url}}"]
        },
        "description": "Basic health check for webhook endpoint"
      },
      "response": []
